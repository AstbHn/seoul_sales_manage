  <JScript><![CDATA[function T_Server_Boot() {

    this.Boot_Server;
    this.Flask_server;

    this.RPAGOTOENABLE = false;
    this.GotoStepRetryCntMap = {};
    this.GotoBlockMap = {};
    this.GotoReverseBlockMap = {};
    this.GotoStepBlockTypeMap = {};


    this.run = function() {

        //------------------------------------------------
        STEP('S9471a6007e0346248b66a759209fc6f7', '[1] ExecuteScript');
        this.Flask_server =`cd C:\\Users\\5Class_012\\Desktop\\project\\Team_1_Main\\Flask
        python app.py
        `;

        this.Boot_Server=`cd C:\\Users\\5Class_012\\Desktop\\project\\Team_1_Main\\team_project
        mvnw spring-boot:run
        `;

        //------------------------------------------------
        STEP('S031d24f07a3a42df9e4f024426c786fe', '[2] OpenApp');
        Flask_CMD = WinApplicationPlayer.OpenApp('CMD', '', false, 5, '');

        //------------------------------------------------
        STEP('Sbeb9087a683e4b518d3e5f08c6aa3b0c', '[3] TextInput');
        StepPlayer.Run('Win.TextInput', this.textinput_info_3);

        //------------------------------------------------
        STEP('Sf541da16dbb944619169f69d77191e1a', '[4] Delay');
        Delay(2000);

        //------------------------------------------------
        STEP('S83f4623c86eb42bbb604a320cc2944f8', '[5] OpenApp');
        Boot_CMD = WinApplicationPlayer.OpenApp('CMD', '', false, 5, '');

        //------------------------------------------------
        STEP('S53821d04101443a2bc384df20519ccbb', '[6] TextInput');
        StepPlayer.Run('Win.TextInput', this.textinput_info_6);

        //------------------------------------------------
        STEP('Se06936c5f42f4862b525d45d5519408e', '[7] Delay');
        Delay(7000);


    }

    this.execute = function() {
        var result = null;
        result = this.run()
        if (result != null)
            return result;
    }
}
]]></JScript>
