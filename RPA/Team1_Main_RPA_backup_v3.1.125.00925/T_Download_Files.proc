  <JScript><![CDATA[function T_Download_Files() {

    this.FileExist;
    this.Result_List;
    this.PDF;
    this.CSV;
    this.Result_Route = 'C:\\Users\\5Class_012\\Desktop\\Project_Result\\';

    this.RPAGOTOENABLE = false;
    this.GotoStepRetryCntMap = {};
    this.GotoBlockMap = {6:[8],15:[17]};
    this.GotoReverseBlockMap = {8:6,17:15};
    this.GotoStepBlockTypeMap = {6:'DecisionThen',8:'EndDecisionThen',15:'DecisionThen',17:'EndDecisionThen'};


    this.run = function() {

        //------------------------------------------------
        STEP('S0cd63776d89744718d64094c0e2fb14e', '[1] ChromeGetListData');
        this.Result_List = StepPlayer.Run('Chrome.ChromeGetListData', this.chromegetlistdata_info_1);

        //------------------------------------------------
        STEP('S25457d1dbb22441cb362b7e6da5376cb', '[2] ExecuteScript');
        this.CSV = this.Result_List[0] + this.Result_List[1] + this.Result_List[2] + "분석ㆍ예측보고서.csv";
        this.PDF = this.Result_List[0] + this.Result_List[1] + this.Result_List[2] + "분석ㆍ예측보고서.pdf";

        //------------------------------------------------
        STEP('S76215f0918954da1968f8e59dfcc324c', '[3] IsFileExist');
        this.FileExist = StepPlayer.Run('Desktop.IsFileExist', this.isfileexist_info_3);

        //------------------------------------------------
        STEP('Sfca123365eb247dda29ff7ecd2efb126', '[4] ChromeClick');
        StepPlayer.Run('Chrome.ChromeClick', this.chromeclick_info_4);

        //------------------------------------------------
        STEP('Se5b8b6b8300b49aaa2b7b3e3eff91674', '[5] TextInput');
        StepPlayer.Run('Win.TextInput', this.textinput_info_5);

        //------------------------------------------------
        STEP('S4bb1e8485d5b4972b13a4c037464ae8e', '[6] IfThen');
        if (this.FileExist== true) {

            //------------------------------------------------
            STEP('S1dce8583b01b454ca090c1c057a75687', '[7] Click');
            StepPlayer.Run('Win.Click', this.click_info_7);

        //------------------------------------------------
        }
        STEP('S6b750ceab06b48b8b75675fc83895b5c', '[8] End-IfThen');

        //------------------------------------------------
        STEP('S482c308ea74546c9bcd6e880c6a6c679', '[9] Delay');
        Delay(1000);

        //------------------------------------------------
        STEP('Sabf2915202924ffe87a99eda4ca6c999', '[10] OpenExcel');
        RESULT = StepPlayer.Run('Excel.OpenExcel', this.openexcel_info_10);

        //------------------------------------------------
        STEP('S6b20e926ba474aadb35c1c876a4bd3c4', '[11] Delay');
        Delay(2000);

        //------------------------------------------------
        STEP('S66a8b8ebfac24036bb00eadec9d30603', '[12] CloseExcel');
        StepPlayer.Run('Excel.CloseExcel', this.closeexcel_info_12);

        //------------------------------------------------
        STEP('Sc3d2e0a57c2b49ab948ae94d531431a1', '[13] ChromeClick');
        StepPlayer.Run('Chrome.ChromeClick', this.chromeclick_info_13);

        //------------------------------------------------
        STEP('S2e5ff02db5b24bb8b8b347a111e77655', '[14] TextInput');
        StepPlayer.Run('Win.TextInput', this.textinput_info_14);

        //------------------------------------------------
        STEP('S0a9fa846b9fa4282a8139b8af71cb7aa', '[15] IfThen');
